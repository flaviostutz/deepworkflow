# Non-secret Azure OpenAI configuration
# Secrets (API keys) are stored in the OS keychain via 'make setup-secrets'
DEEPWORKFLOW_AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
DEEPWORKFLOW_API_VERSION=2024-02-15-preview
DEEPWORKFLOW_MODEL=gpt-4o
DEEPWORKFLOW_MODEL_PROVIDER=azure_openai
